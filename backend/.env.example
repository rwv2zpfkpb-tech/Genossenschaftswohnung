DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/genossenschaft

# Resend (https://resend.com) -> API Keys
RESEND_API_KEY=
MAIL_FROM=onboarding@resend.dev
NOTIFY_EMAIL_TO=

FRONTEND_ORIGIN=http://localhost:5173

# Geocoding via Nominatim (https://nominatim.org). Deren Nutzungsbedingungen
# verlangen einen identifizierenden User-Agent - im Idealfall mit Kontakt
# (z.B. App-Name + E-Mail oder Projekt-URL), siehe
# https://operations.osmfoundation.org/policies/nominatim/
NOMINATIM_USER_AGENT=genossenschaft-wohnungssuche/1.0 (contact@example.com)
